{
  "name": "auto-talon",
  "version": "0.1.0",
  "description": "CLI-first agent runtime with governance and traceability",
  "type": "module",
  "license": "MIT",
  "main": "dist/runtime/index.js",
  "types": "dist/runtime/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XD319/auto-talon.git"
  },
  "bugs": {
    "url": "https://github.com/XD319/auto-talon/issues"
  },
  "homepage": "https://github.com/XD319/auto-talon#readme",
  "keywords": [
    "agent",
    "cli",
    "typescript",
    "ai",
    "mcp"
  ],
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "talon": "dist/cli/bin.js"
  },
  "files": [
    "dist/",
    "fixtures/runtime-smoke-tasks.json",
    "docs/",
    "scripts/setup.sh",
    "scripts/setup.ps1",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm test && npm run coverage && npm run build",
    "dev": "node --disable-warning=ExperimentalWarning --import tsx src/cli/bin.ts",
    "dev:tui": "node --disable-warning=ExperimentalWarning --import tsx src/cli/bin.ts tui",
    "dev:dashboard": "node --disable-warning=ExperimentalWarning --import tsx src/cli/bin.ts dashboard",
    "prepack": "pnpm run build",
    "release:check": "node --disable-warning=ExperimentalWarning --import tsx src/cli/bin.ts release check",
    "setup": "node --disable-warning=ExperimentalWarning --import tsx src/cli/bin.ts init --yes",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "clipboardy": "^3.0.0",
    "commander": "^14.0.0",
    "highlight.js": "^11.11.1",
    "ink": "^7.0.1",
    "node-html-parser": "^6.1.13",
    "react": "^19.2.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
